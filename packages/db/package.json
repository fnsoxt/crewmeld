{
  "name": "@crewmeld/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "bun": ">=1.2.13",
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    },
    "./schema": {
      "types": "./schema.ts",
      "default": "./schema.ts"
    },
    "./seed/seed-templates": {
      "types": "./seed/seed-templates.ts",
      "default": "./seed/seed-templates.ts"
    }
  },
  "scripts": {
    "db:push": "bunx drizzle-kit push --config=./drizzle.config.ts",
    "db:generate": "bunx drizzle-kit generate --config=./drizzle.config.ts",
    "db:migrate": "bunx drizzle-kit migrate --config=./drizzle.config.ts",
    "db:studio": "bunx drizzle-kit studio --config=./drizzle.config.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@crewmeld/logger": "workspace:*",
    "drizzle-orm": "^0.44.5",
    "postgres": "^3.4.5",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@crewmeld/tsconfig": "workspace:*",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  }
}
